{
  "id": "garmin",
  "name": "Garmin",
  "version": "1.3.0",
  "description": "Your Garmin Connect health data: steps, Body Battery, sleep, activities, and weekly training.",
  "author": "home-screens",
  "license": "MIT",
  "minAppVersion": "1.8.0",
  "moduleType": "garmin",
  "category": "Health & Fitness",
  "icon": "Activity",

  "auth": { "type": "garmin" },
  "allowedDomains": ["connectapi.garmin.com"],
  "permissions": ["network", "oauth"],

  "defaultConfig": {
    "view": "summary",
    "units": "metric",
    "activityCount": 4,
    "sportFilter": "all",
    "weeklyStyle": "bySport",
    "weeklyWindow": "calendar",
    "refreshIntervalMs": 900000
  },

  "defaultSize": { "w": 520, "h": 640 },

  "defaultStyle": {
    "padding": 20,
    "backgroundColor": "rgba(0, 0, 0, 0.45)"
  },

  "configSchema": {
    "type": "object",
    "properties": {
      "view": {
        "type": "string",
        "title": "View",
        "ui:widget": "select",
        "enum": ["summary", "bodyBattery", "stress", "sleep", "activities", "latestActivity", "weekly", "trainingReadiness", "trainingStatus", "hrv", "heartRate", "racePredictions", "records", "weight"],
        "enumLabels": ["Daily summary", "Body Battery", "Stress", "Sleep", "Activities", "Latest activity", "Weekly training", "Training readiness", "Training status", "HRV status", "Heart rate", "Race predictions", "Personal records", "Weight"],
        "ui:group": "Layout"
      },
      "units": {
        "type": "string",
        "title": "Units",
        "ui:widget": "select",
        "enum": ["metric", "imperial"],
        "enumLabels": ["Metric (km)", "Imperial (mi)"],
        "ui:group": "Layout"
      },
      "activityCount": {
        "type": "number",
        "title": "Activities to show",
        "minimum": 1,
        "maximum": 10,
        "ui:widget": "slider",
        "ui:step": 1,
        "ui:group": "Activities",
        "ui:showWhen": { "field": "view", "equals": "activities" }
      },
      "sportFilter": {
        "type": "string",
        "title": "Sport",
        "description": "Applies to the Activities, Latest activity, and Weekly training views.",
        "ui:widget": "select",
        "enum": ["all", "running", "cycling", "swimming", "walking", "hiking", "strength"],
        "enumLabels": ["All sports", "Running", "Cycling", "Swimming", "Walking", "Hiking", "Strength"],
        "ui:group": "Activities"
      },
      "weeklyStyle": {
        "type": "string",
        "title": "Weekly list",
        "ui:widget": "select",
        "enum": ["bySport", "individual"],
        "enumLabels": ["Group by sport", "List each workout"],
        "ui:group": "Layout",
        "ui:showWhen": { "field": "view", "equals": "weekly" }
      },
      "weeklyWindow": {
        "type": "string",
        "title": "Week",
        "ui:widget": "select",
        "enum": ["calendar", "rolling"],
        "enumLabels": ["This week (like Garmin)", "Last 7 days"],
        "ui:group": "Layout",
        "ui:showWhen": { "field": "view", "equals": "weekly" }
      },
      "refreshIntervalMs": {
        "type": "number",
        "title": "Refresh interval",
        "minimum": 300000,
        "maximum": 3600000,
        "ui:widget": "slider",
        "ui:step": 300000,
        "ui:group": "Timing"
      }
    }
  },

  "providesState": [
    { "key": "body_battery", "label": "Body Battery level", "sampleValues": ["78", "25"] },
    { "key": "sleep_score", "label": "Sleep score", "sampleValues": ["82", "44"] },
    { "key": "steps", "label": "Steps today", "sampleValues": ["8421"] }
  ],

  "exports": {
    "component": "default",
    "configSection": "ConfigSection",
    "stateProvider": "StateProvider"
  },

  "dataRequirements": [],
  "prefetchUrl": null
}
